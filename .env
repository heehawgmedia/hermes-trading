# Mode: "paper" (in-memory simulation) or "live" (Alpaca real orders)
HERMES_TRADING_MODE=paper
HERMES_TRADING_I_ACCEPT_RISK=false

# Paper executor starting balance (only used when MODE=paper)
PAPER_STARTING_CASH=10000

# Alpaca live trading (only used when MODE=live)
# Get keys from https://alpaca.markets/ → Paper Trading → API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Default = Alpaca's PAPER endpoint (safe). Flip to live ONLY after confirming
# the agent fires correct orders on the paper endpoint.
#   PAPER: https://paper-api.alpaca.markets
#   LIVE:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Kill switch: max single position as fraction of cash. 0.02 = 2%.
# In live mode, any order exceeding this is rejected.
MAX_POSITION_PCT=0.02

# Optional adapter API keys (free public fallbacks used if blank)
GLASSNODE_API_KEY=
NEWS_API_KEY=
